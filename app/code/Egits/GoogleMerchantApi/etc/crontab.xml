<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="google_merchant_sync_products" instance="Egits\GoogleMerchantApi\Cron\SyncProduct" method="execute">
            <schedule>*/10 * * * *</schedule>
        </job>
        <job name="google_merchant_sync_missing_products" instance="Egits\GoogleMerchantApi\Cron\SyncMissingProduct" method="execute">
            <schedule>*/15 * * * *</schedule>
        </job>
        <job name="google_merchant_add_products_to_internal_queue" instance="Egits\GoogleMerchantApi\Cron\AddProductsToInternalQueue" method="execute">
            <schedule>* * * * *</schedule>
        </job>
    </group>
</config>
